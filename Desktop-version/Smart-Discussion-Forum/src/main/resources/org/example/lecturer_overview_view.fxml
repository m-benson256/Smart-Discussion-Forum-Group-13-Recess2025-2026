<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.LecturerOverviewController"
      spacing="20">

    <!-- Search bar -->
    <TextField fx:id="searchField" promptText="Search for quizzes, students, or reports... (press Enter)"
               styleClass="text-input"/>

    <!-- Welcome card + stat pills -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <VBox styleClass="card" spacing="6" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            <Label fx:id="welcomeLabelOverview" text="Welcome Lecturer" styleClass="title-label" style="-fx-font-size: 26px;"/>
        </VBox>
        <VBox styleClass="card" spacing="4" alignment="CENTER">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label text="TOTAL STUDENTS" styleClass="muted-label"/>
            <Label fx:id="totalStudentsLabel" text="0" styleClass="title-label"/>
        </VBox>
        <VBox styleClass="card" spacing="4" alignment="CENTER">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label text="TOPICS" styleClass="muted-label"/>
            <Label fx:id="topicsLabel" text="0" styleClass="title-label"/>
        </VBox>
    </HBox>

    <!-- Quiz Configuration section -->
    <VBox styleClass="card" spacing="16" VBox.vgrow="ALWAYS">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Quiz Configuration" styleClass="title-label"/>
                <Label text="Manage, create, and schedule student assessments." styleClass="muted-label"/>
            </VBox>
            <Button text="+ Create New Quiz" onAction="#handleCreateQuiz" styleClass="button-primary"/>
        </HBox>

        <HBox spacing="24">
            <Button fx:id="tabAllQuizzes" text="All Quizzes" onAction="#showAllQuizzes" styleClass="link-label"/>
            <Button fx:id="tabScheduled" text="Scheduled" onAction="#showScheduled" styleClass="nav-button"/>
            <Button fx:id="tabPastDue" text="Past Due" onAction="#showPastDue" styleClass="nav-button"/>
        </HBox>

        <ScrollPane fitToWidth="true" styleClass="edge-to-edge" VBox.vgrow="ALWAYS">
            <VBox fx:id="quizListContainer" spacing="10">
                <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
            </VBox>
        </ScrollPane>
    </VBox>
</VBox>