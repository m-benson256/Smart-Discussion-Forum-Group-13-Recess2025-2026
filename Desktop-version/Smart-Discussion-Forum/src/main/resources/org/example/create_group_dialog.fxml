<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.CreateGroupController" styleClass="glass-card">
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <Label text="Create a Group" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>

    <TextField fx:id="nameField" promptText="Group name"/>
    <TextArea fx:id="descriptionField" promptText="Description" prefRowCount="3" wrapText="true"/>

    <ComboBox fx:id="visibilityDropdown" promptText="Visibility"/>

    <Label fx:id="statusLabel" wrapText="true" style="-fx-text-fill: #ff3333;"/>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-secondary"/>
        <Button text="Create" onAction="#handleCreate" styleClass="button-primary"/>
    </HBox>
</VBox>
