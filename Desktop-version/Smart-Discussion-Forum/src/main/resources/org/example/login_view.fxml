<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="700.0" prefWidth="900.0" styleClass="root-pane" stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://github.com/fxml/1"
           fx:controller="org.example.LoginController">
    <children>

        <VBox alignment="CENTER" fillWidth="false" prefWidth="420.0" spacing="15.0"
              styleClass="glass-card" stylesheets="@style.css" StackPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/>
            </padding>
            <children>
                <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Sign In"/>

                <VBox prefWidth="320.0" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: white;" text="Email Address"/>
                        <TextField fx:id="emailField" promptText="Email address"/>
                    </children>
                </VBox>

                <VBox prefWidth="320.0" spacing="5.0">
                    <children>
                        <Label style="-fx-text-fill: white;" text="Password"/>
                        <PasswordField fx:id="passwordField" promptText="Password"/>
                    </children>
                </VBox>

                <Label fx:id="statusLabel" alignment="CENTER" prefWidth="320.0"
                       style="-fx-text-fill: #ff3333; -fx-font-weight: bold;"
                       textAlignment="CENTER" wrapText="true"/>

                <Button fx:id="loginButton" onAction="#handleLoginSubmit" prefWidth="320.0"
                        styleClass="button-primary" text="Log In"/>

                <Label onMouseClicked="#goToRegister" styleClass="link-label"
                       text="Don't have an account? Register"/>
            </children>
        </VBox>
    </children>
</StackPane>
