<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16" styleClass="root-container"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.LoginController">

    <padding>
        <Insets top="60" right="60" bottom="60" left="60"/>
    </padding>

    <Label text="Sign In" styleClass="title-label"/>

    <TextField fx:id="emailField" promptText="Email address" maxWidth="320"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="320"/>

    <Label fx:id="statusLabel" wrapText="true" maxWidth="320"/>

    <Button text="Log In" onAction="#handleLoginSubmit" styleClass="button-primary" maxWidth="320"/>

    <Label text="Don't have an account? Register" onMouseClicked="#goToRegister" styleClass="link-label"/>

</VBox>
