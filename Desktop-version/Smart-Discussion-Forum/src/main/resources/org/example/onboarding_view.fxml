<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.OnboardingController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="What are you interested in?" styleClass="title-label"/>
    <Label text="Pick a few topics to personalize your recommendations, or skip for now." wrapText="true"/>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10">
            <CheckBox fx:id="mlCheck" text="Machine Learning" userData="ml"/>
            <CheckBox fx:id="webCheck" text="Web Development" userData="web"/>
            <CheckBox fx:id="dbCheck" text="Database Systems" userData="db"/>
            <CheckBox fx:id="mobileCheck" text="Mobile Engineering" userData="mobile"/>
            <CheckBox fx:id="securityCheck" text="Cybersecurity" userData="security"/>
            <CheckBox fx:id="designCheck" text="UI/UX Design" userData="design"/>
            <CheckBox fx:id="cloudCheck" text="Cloud Computing" userData="cloud"/>
            <CheckBox fx:id="dataCheck" text="Data Science" userData="data"/>
            <CheckBox fx:id="aiCheck" text="Artificial Intelligence" userData="ai"/>
        </VBox>
    </ScrollPane>

    <Label fx:id="statusLabel" wrapText="true"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Skip for now" onAction="#handleContinue" styleClass="link-label"/>
        <Button text="Complete Registration" onAction="#handleContinue" styleClass="button-primary"/>
    </HBox>

</VBox>
