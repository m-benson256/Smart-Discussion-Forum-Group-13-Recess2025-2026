<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.AnnouncementsController" styleClass="edge-to-edge">
    <VBox spacing="16">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24"/>
        </padding>

        <Label text="Announcements" styleClass="title-label"/>

        <VBox fx:id="announcementsContainer" spacing="14"/>
    </VBox>
</ScrollPane>
