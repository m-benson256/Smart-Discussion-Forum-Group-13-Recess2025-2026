<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.LecturerQuizzesController"
      spacing="16">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Quiz Management" styleClass="title-label"/>
            <Label text="Manage, create, and schedule student assessments." styleClass="muted-label"/>
        </VBox>
        <Button text="+ Create New Assessment" onAction="#handleCreateQuiz" styleClass="button-primary"/>
    </HBox>

    <HBox spacing="24">
        <Button fx:id="tabAllQuizzes" text="All Quizzes" onAction="#showAllQuizzes" styleClass="link-label"/>
        <Button fx:id="tabScheduled" text="Scheduled" onAction="#showScheduled" styleClass="nav-button"/>
        <Button fx:id="tabPastDue" text="Past Due" onAction="#showPastDue" styleClass="nav-button"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="edge-to-edge" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="quizListContainer" hgap="16" vgap="16">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>
        </FlowPane>
    </ScrollPane>
</VBox>