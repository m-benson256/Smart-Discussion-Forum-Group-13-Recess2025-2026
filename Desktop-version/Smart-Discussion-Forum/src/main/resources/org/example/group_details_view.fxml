<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.GroupDetailsController">

    <Button text="&lt; Back to Groups" onAction="#handleBack" styleClass="link-label"/>

    <Label fx:id="nameLabel" styleClass="title-label"/>
    <Label fx:id="descriptionLabel" wrapText="true" styleClass="muted-label"/>
    <Label fx:id="memberCountLabel" styleClass="muted-label"/>

    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="actionButton" onAction="#handleActionButton" styleClass="button-primary"/>
        <Button fx:id="createTopicButton" text="+ Create Topic" onAction="#handleCreateTopic"
                styleClass="button-primary" visible="false" managed="false"/>
    </HBox>

    <Label text="Topics" styleClass="title-label">
        <VBox.margin>
            <Insets top="20"/>
        </VBox.margin>
    </Label>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="edge-to-edge">
        <VBox fx:id="topicsContainer" spacing="10"/>
    </ScrollPane>


    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

</VBox>
